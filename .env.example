# Copy to .env and fill values from Supabase → Project Settings → API
#
# If you open only the project URL in a browser (e.g. https://xxxx.supabase.co), you will see:
#   {"error":"requested path is invalid"}
# That is expected — the API lives at paths like /rest/v1/. This app uses supabase-js which adds them.
# Do not add a path to VITE_SUPABASE_URL; use the hostname only, no trailing slash.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# "anon" "public" JWT from the same API page (starts with eyJ...), OR use the optional name below.
VITE_SUPABASE_ANON_KEY=

# Optional: if your dashboard only shows a publishable key under this env-style name, you can use
# this instead of VITE_SUPABASE_ANON_KEY (only one key is required).
# VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
